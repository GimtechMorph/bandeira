{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Abrir checkin.html",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/checkin.html"
    },
    {
      "name": "Abrir index.html",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/index.html"
    },
    {
      "name": "Check-in (servidor local :8080)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080/checkin.html"
    }
  ]
}
